Screen {
    layout: horizontal;
}

#filer {
    width: 26;
    min-width: 18;
    border-right: solid $accent;
}

#center {
    width: 1fr;
}

/* The C-x prefix hint shown in the footer area. */
#prefix-hint {
    dock: bottom;
    height: 1;
    background: $accent;
    color: $text;
    padding: 0 1;
    display: none;
}

#prefix-hint.active {
    display: block;
}
